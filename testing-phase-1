cat > setup_outline_max.sh << 'EOF'
#!/bin/bash
set -e

echo "Starting Maximum Aggression Shadowsocks Setup for Outline..."

# 1. Set Your Fixed Password Here
STATIC_PASSWORD="fastpass123"
SERVER_IP=$(curl -s -4 ifconfig.me)

# 2. Install Core Dependencies
apt update -y
DEBIAN_FRONTEND=noninteractive apt install -y shadowsocks-libev libcap2-bin iptables net-tools iptables-persistent

# 3. Allow ss-server root-level network binding
setcap 'cap_net_bind_service=+ep' /usr/bin/ss-server
useradd -r -s /sbin/nologin -M shadowsocks 2>/dev/null || true

# 4. Configure Shadowsocks (Optimized for Outline)
mkdir -p /etc/shadowsocks-libev
cat > /etc/shadowsocks-libev/config.json << EOF_JSON
{
    "server":"0.0.0.0",
    "server_port":443,
    "password":"$STATIC_PASSWORD",
    "method":"chacha20-ietf-poly1305",
    "timeout":300,
    "fast_open":true,
    "tcp_nodelay":true,
    "workers":$(nproc)
}
EOF_JSON
chown -R shadowsocks:shadowsocks /etc/shadowsocks-libev
chmod 600 /etc/shadowsocks-libev/config.json

# 5. Ultra-Advanced Kernel Tuning for Single-Connection Speed
# Removed the invalid tcp_nodelay rule. The rest are highly optimized for cloud VPS environments.
cat > /etc/sysctl.d/99-shadowsocks-max.conf << EOF_SYSCTL
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_base_mss=1024
net.ipv4.tcp_window_scaling=1
net.ipv4.tcp_adv_win_scale=1
net.core.rmem_max=33554432
net.core.wmem_max=33554432
net.ipv4.tcp_rmem=4096 87380 33554432
net.ipv4.tcp_wmem=4096 65536 33554432
net.core.netdev_max_backlog=100000
net.core.somaxconn=65535
net.ipv4.tcp_max_syn_backlog=65535
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_fin_timeout=15
net.ipv4.tcp_slow_start_after_idle=0
net.ipv4.tcp_no_metrics_save=1
EOF_SYSCTL
sysctl -p /etc/sysctl.d/99-shadowsocks-max.conf
modprobe tcp_bbr 2>/dev/null || true

# 6. Persistent Firewall Rules (TCP & UDP)
iptables -A INPUT -p tcp --dport 22 -j ACCEPT
iptables -A OUTPUT -p tcp --sport 22 -j ACCEPT
iptables -A INPUT -p tcp --dport 443 -j ACCEPT
iptables -A OUTPUT -p tcp --sport 443 -j ACCEPT
iptables -A INPUT -p udp --dport 443 -j ACCEPT
iptables -A OUTPUT -p udp --sport 443 -j ACCEPT
netfilter-persistent save >/dev/null 2>&1

# 7. Systemd Service with UDP Relay Enabled (-u)
cat > /etc/systemd/system/shadowsocks-libev.service << EOF_SYSTEMD
[Unit]
Description=Shadowsocks-libev Outline Server
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/ss-server -c /etc/shadowsocks-libev/config.json -u
Restart=always
RestartSec=3
User=shadowsocks
Group=shadowsocks
LimitNOFILE=1048576
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
EOF_SYSTEMD

# 8. Start Service
systemctl daemon-reload
systemctl enable shadowsocks-libev
systemctl restart shadowsocks-libev
sleep 2

# 9. Output Static Outline Link
if systemctl is-active --quiet shadowsocks-libev; then
    echo -e "\n=================================================================="
    echo -e "✅ MAX SPEED OUTLINE SETUP COMPLETE"
    echo -e "=================================================================="
    echo -e "Copy this URL and paste it into Outline Client:"
    echo -e "\nss://chacha20-ietf-poly1305:${STATIC_PASSWORD}@${SERVER_IP}:443\n"
    echo -e "=================================================================="
else
    echo "❌ Failed: Service is not running."
    journalctl -u shadowsocks-libev --no-pager | tail -n 10
fi
EOF

bash setup_outline_max.sh
