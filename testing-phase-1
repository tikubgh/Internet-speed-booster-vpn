cat > setup_optimized.sh << 'EOF'
#!/bin/bash
set -e

echo "Starting optimized Shadowsocks-libev installation..."

# 1. Get Server IP
SERVER_IP=$(curl -s ifconfig.me)

# 2. Install dependencies (added iptables-persistent to save rules after reboot)
apt update -y
DEBIAN_FRONTEND=noninteractive apt install -y shadowsocks-libev libcap2-bin iptables net-tools iptables-persistent

# 3. Allow ss-server to bind to low ports
setcap 'cap_net_bind_service=+ep' /usr/bin/ss-server

# 4. Create dedicated user
useradd -r -s /sbin/nologin -M shadowsocks 2>/dev/null || true

# 5. Generate a secure, random password (No more hardcoded 'fastpass123')
PASSWORD=$(tr -dc A-Za-z0-9 </dev/urandom | head -c 16)

# 6. Configure Shadowsocks
mkdir -p /etc/shadowsocks-libev
cat > /etc/shadowsocks-libev/config.json << EOF_JSON
{
    "server":"0.0.0.0",
    "server_port":443,
    "password":"$PASSWORD",
    "method":"aes-256-gcm",
    "timeout":300,
    "fast_open":true,
    "tcp_nodelay":true,
    "workers":$(nproc)
}
EOF_JSON
chown -R shadowsocks:shadowsocks /etc/shadowsocks-libev
chmod 600 /etc/shadowsocks-libev/config.json

# 7. Optimize Network Kernel (Sysctl) - Tuned for high speed but safe for VPS memory
cat > /etc/sysctl.d/99-shadowsocks.conf << EOF_SYSCTL
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
net.ipv4.tcp_fastopen=3
net.core.rmem_max=16777216
net.core.wmem_max=16777216
net.ipv4.tcp_rmem=4096 87380 16777216
net.ipv4.tcp_wmem=4096 65536 16777216
net.core.netdev_max_backlog=500000
net.core.somaxconn=524288
net.ipv4.tcp_max_syn_backlog=524288
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_window_scaling=1
net.ipv4.tcp_base_mss=1460
net.ipv4.tcp_low_latency=1
net.ipv4.tcp_no_metrics_save=1
EOF_SYSCTL
sysctl -p /etc/sysctl.d/99-shadowsocks.conf
modprobe tcp_bbr 2>/dev/null || true

# 8. Setup Firewall for TCP & UDP, then Save Persistence
iptables -A INPUT -p tcp --dport 22 -j ACCEPT
iptables -A OUTPUT -p tcp --sport 22 -j ACCEPT
iptables -A INPUT -p tcp --dport 443 -j ACCEPT
iptables -A OUTPUT -p tcp --sport 443 -j ACCEPT
iptables -A INPUT -p udp --dport 443 -j ACCEPT
iptables -A OUTPUT -p udp --sport 443 -j ACCEPT
netfilter-persistent save

# 9. Setup Systemd Service (CRITICAL: Added '-u' to enable UDP relay)
cat > /etc/systemd/system/shadowsocks-libev.service << EOF_SYSTEMD
[Unit]
Description=Shadowsocks-libev Server (Speed Optimized)
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/ss-server -c /etc/shadowsocks-libev/config.json -u
Restart=always
RestartSec=3
User=shadowsocks
Group=shadowsocks
LimitNOFILE=1048576
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
EOF_SYSTEMD

# 10. Start and verify
systemctl daemon-reload
systemctl enable shadowsocks-libev
systemctl restart shadowsocks-libev
sleep 2

if systemctl is-active --quiet shadowsocks-libev; then
    echo -e "\n=================================================================="
    echo -e "✅ SETUP COMPLETE! Optimized for Speed, UDP, and Stability."
    echo -e "Copy this URL and paste it into your Outline Client:"
    echo -e "\nss://aes-256-gcm:${PASSWORD}@${SERVER_IP}:443"
    echo -e "\n=================================================================="
else
    echo "❌ Failed: Service is not running. Check logs:"
    journalctl -u shadowsocks-libev --no-pager | tail -n 20
    exit 1
fi
EOF

bash setup_optimized.sh
